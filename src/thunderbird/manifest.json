{
  "manifest_version": 3,
  "author": "SECUSO",
  "browser_specific_settings": {
    "gecko": {
      "id": "torpedo@tu-darmstadt.de",
      "strict_min_version": "128.0"
    }
  },
  "name": "__MSG_extensionName__",
  "version": "4.0.3",
  "default_locale": "en",
  "description": "__MSG_extensionDescriptionThunderbird__",
  "background": {
    "scripts": [
      "service_worker.js"
    ]
  },
  "permissions": [
    "activeTab",
    "storage",
    "messagesRead",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_ui": {
    "page": "options.html"
  },
  "icons": {
    "38": "img/icon38.png",
    "64": "img/icon64.png"
  },
  "action": {
    "default_title": "__MSG_extensionName__",
    "default_popup": "icon.html",
    "default_icon": {
      "38": "img/none38.png",
      "32": "img/none64.png"
    },
    "allowed_spaces": [
      "mail",
      "default"
    ]
  }
}